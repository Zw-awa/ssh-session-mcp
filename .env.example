# Legacy single-device SSH settings
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USER=username
# Use either password or key (key is recommended)
SSH_PASSWORD=
SSH_KEY=

# Instance / profile settings
# SSH_MCP_INSTANCE=default
# SSH_MCP_CONFIG=./ssh-session-mcp.config.json

# Viewer settings
VIEWER_HOST=127.0.0.1
VIEWER_PORT=auto
VIEWER_REFRESH_MS=1000

# Auto open xterm.js terminal page in browser when AI opens a session
AUTO_OPEN_TERMINAL=false

# Operation / logging
SSH_MCP_MODE=safe
SSH_MCP_USE_MARKER=true
SSH_MCP_LOG_MODE=off
# SSH_MCP_LOG_DIR=
