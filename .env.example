# SSH connection settings
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USER=username
# Use either password or key (key is recommended)
SSH_PASSWORD=
SSH_KEY=

# Viewer settings (optional)
VIEWER_HOST=127.0.0.1
VIEWER_PORT=8793
VIEWER_REFRESH_MS=1000

# Session settings (optional)
SESSION_NAME=ssh-session-mcp-demo
STARTUP_INPUT=hostname && whoami && pwd
STARTUP_INPUT_ACTOR=codex
